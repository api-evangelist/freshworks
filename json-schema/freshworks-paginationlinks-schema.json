{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/PaginationLinks",
  "title": "PaginationLinks",
  "type": "object",
  "properties": {
    "next_page": {
      "type": "string",
      "format": "uri",
      "description": "URL for the next page of results."
    },
    "prev_page": {
      "type": "string",
      "format": "uri",
      "description": "URL for the previous page of results."
    }
  }
}