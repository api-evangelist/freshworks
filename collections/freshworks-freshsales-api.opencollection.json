      "info": {
        "name": "Contacts",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List all contacts",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{domain}.myfreshworks.com/crm/sales/api/contacts",
            "params": [
              {
                "name": "page",
                "value": "",
                "type": "query",
                "description": "Page number for pagination."
              },
              {
                "name": "sort",
                "value": "",
                "type": "query",
                "description": "Field to sort by."
              },
              {
                "name": "sort_type",
                "value": "",
                "type": "query",
                "description": "Sort order direction."
              },
              {
                "name": "filter",
                "value": "",
                "type": "query",
                "description": "Pre-defined view filter to apply."
              }
            ]
          },
          "docs": "Retrieves a paginated list of all contacts in the CRM. Supports filtering and sorting by various contact fields."
        },
        {
          "info": {
            "name": "Create a contact",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://{domain}.myfreshworks.com/crm/sales/api/contacts",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a new contact in the CRM with the specified properties."
        },
        {
          "info": {
            "name": "View a contact",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{domain}.myfreshworks.com/crm/sales/api/contacts/:contact_id",
            "params": [
              {
                "name": "contact_id",
                "value": "",
                "type": "path",
                "description": "The ID of the contact."
              }
            ]
          },
          "docs": "Retrieves the details of a specific contact by their ID."
        },
        {
          "info": {
            "name": "Update a contact",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://{domain}.myfreshworks.com/crm/sales/api/contacts/:contact_id",
            "params": [
              {
                "name": "contact_id",
                "value": "",
                "type": "path",
                "description": "The ID of the contact."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Updates the properties of an existing contact."
        },
        {
          "info": {
            "name": "Delete a contact",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://{domain}.myfreshworks.com/crm/sales/api/contacts/:contact_id",
            "params": [
              {
                "name": "contact_id",
                "value": "",
                "type": "path",
                "description": "The ID of the contact."
              }
            ]
          },
          "docs": "Deletes a contact from the CRM."
        }
      ]
    },
